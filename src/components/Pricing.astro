---
const plans = [
  {
    name: 'Starter',
    price: '$50',
    period: 'per seat / month',
    description: 'Everything your team needs to start shipping with AI agents.',
    cta: 'Get started',
    ctaHref: '#book-demo',
    featured: false,
    features: [
      'Unlimited workflows',
      'Up to 10 team members',
      'GitHub integration',
      'Visual agent DAG editor',
      'Workflow chat & notifications',
      'Pre-built agent toolkit',
      'Cloud execution environment',
      'Global API key management',
      'Email support',
    ],
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: 'contact us for pricing',
    description: 'For organizations that need custom deployments, SSO, and dedicated support.',
    cta: 'Contact sales',
    ctaHref: 'mailto:sales@overnightai.app',
    featured: true,
    features: [
      'Everything in Starter',
      'Unlimited seats',
      'SSO & custom domain login',
      'Custom knowledge bases',
      'Fine-grained role permissions',
      'Dedicated cloud environment',
      'Priority support & SLA',
      'Custom model configurations',
      'Slack / Teams / Chat integrations',
      'Dedicated onboarding & success manager',
    ],
  },
];
---

<section class="pricing" id="pricing">
  <div class="container">
    <div class="pricing-header">
      <span class="section-label">Pricing</span>
      <h2 class="section-title">
        Simple, transparent<br />
        <span class="gradient-text">pricing</span>
      </h2>
      <p class="section-subtitle">
        Start shipping with AI agents today. Scale to enterprise when you're ready.
      </p>
    </div>

    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`pricing-card ${plan.featured ? 'pricing-card-featured' : ''}`}>
          {plan.featured && (
            <div class="featured-badge">Most popular</div>
          )}
          <div class="plan-header">
            <h3 class="plan-name">{plan.name}</h3>
            <div class="plan-price">
              <span class="price-amount">{plan.price}</span>
              {plan.price !== 'Custom' && <span class="price-currency"></span>}
            </div>
            <p class="plan-period">{plan.period}</p>
            <p class="plan-description">{plan.description}</p>
          </div>

          <a
            href={plan.ctaHref}
            class={plan.featured ? 'btn-primary plan-cta' : 'btn-secondary plan-cta'}
          >
            {plan.cta}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7H11.5M11.5 7L8 3.5M11.5 7L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <ul class="plan-features" role="list">
            {plan.features.map((feature) => (
              <li class="plan-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="7" fill="url(#check-gradient)" fill-opacity="0.15" stroke="url(#check-gradient)" stroke-opacity="0.4"/>
                  <path d="M5 8L7 10.5L11 5.5" stroke="url(#check-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <defs>
                    <linearGradient id="check-gradient" x1="1" y1="1" x2="15" y2="15" gradientUnits="userSpaceOnUse">
                      <stop stop-color="#818cf8"/>
                      <stop offset="1" stop-color="#c084fc"/>
                    </linearGradient>
                  </defs>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pricing-note">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2" opacity="0.5"/>
        <path d="M8 5V8.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <circle cx="8" cy="11" r="0.75" fill="currentColor"/>
      </svg>
      All plans include a 14-day free trial. No credit card required to start.
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 100px 0;
    position: relative;
  }

  .pricing::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgb(99 102 241 / 0.3), transparent);
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .pricing-header .section-subtitle {
    margin: 0 auto;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 820px;
    margin: 0 auto;
  }

  .pricing-card {
    position: relative;
    background: var(--gray-900);
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: var(--radius-xl);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    transition: border-color 0.2s;
  }

  .pricing-card:hover {
    border-color: rgb(99 102 241 / 0.3);
  }

  .pricing-card-featured {
    border-color: rgb(99 102 241 / 0.4);
    background: linear-gradient(160deg, rgb(99 102 241 / 0.08) 0%, var(--gray-900) 60%);
    box-shadow: 0 0 60px -20px rgb(99 102 241 / 0.3);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 16px;
    background: linear-gradient(135deg, var(--indigo-600), var(--purple-600));
    border-radius: var(--radius-full);
    font-size: 12px;
    font-weight: 600;
    color: white;
    white-space: nowrap;
  }

  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .plan-name {
    font-size: 20px;
    font-weight: 700;
    color: var(--white);
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-top: 4px;
  }

  .price-amount {
    font-size: 44px;
    font-weight: 900;
    color: var(--white);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .plan-period {
    font-size: 13px;
    color: var(--gray-500);
  }

  .plan-description {
    font-size: 14px;
    color: var(--gray-400);
    line-height: 1.6;
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .plan-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--gray-400);
    line-height: 1.5;
  }

  .plan-feature svg {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pricing-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
    font-size: 14px;
    color: var(--gray-600);
  }

  @media (max-width: 640px) {
    .pricing {
      padding: 72px 0;
    }

    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card {
      padding: 28px 24px;
    }
  }
</style>
