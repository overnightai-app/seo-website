{
  "version": 1,
  "framework": {
    "name": "astro",
    "version": "5.18.1"
  },
  "routes": [
    {
      "path": "/*",
      "target": {
        "kind": "Static"
      },
      "fallback": {
        "kind": "Static",
        "uri": "/index.html"
      },
      "condition": "NOT_FOUND"
    }
  ]
}
